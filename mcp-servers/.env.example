# Absolute path to YOUR project's git repo (the one the agents work in).
# It is mounted read-only into the MCP container so the server can read docs
# and resolve historical blobs. Example:
#REPO_HOST_PATH=FILLME
#JIRA_BASE_URL=FILLME
#JIRA_USER_EMAIL=FILLME
#JIRA_API_TOKEN=FILLME
#CG_LANG=FILLME
#LSP_INIT_TIMEOUT=90